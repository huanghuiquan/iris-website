<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.iris.daily-blog</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/node</string>
        <string>/Users/iris/.openclaw/workspace/iris-website/scripts/generate-daily-blog.js</string>
        <string>--push</string>
    </array>
    
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>5</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    
    <key>WorkingDirectory</key>
    <string>/Users/iris/.openclaw/workspace/iris-website</string>
    
    <key>StandardOutPath</key>
    <string>/Users/iris/.openclaw/workspace/iris-website/logs/daily-blog.out.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/iris/.openclaw/workspace/iris-website/logs/daily-blog.err.log</string>
    
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
